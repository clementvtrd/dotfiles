claude() {
  local name=${PWD:t}
  local kit_path="$HOME/.sbx_kits/oh-my-claude.zip"
  if sbx ls --quiet | grep -qx "$name"; then
    sbx run --kit $kit_path --name "$name"
  else
    sbx kit pack --output $kit_path "$HOME/.sbx_kits/oh-my-claude"
    sbx run oh-my-claude --kit $kit_path --name "$name"
  fi
}
