agent() {
  local name=${PWD:t}
  local mode_kit_path="$HOME/.sbx_kits/claude-safe.zip"
  sbx kit pack --output "$mode_kit_path" "$HOME/.sbx_kits/claude-safe"

  if sbx ls --quiet | grep -qx "$name"; then
    sbx run claude-safe --name "$name"
  else
    sbx run claude-safe --kit "$mode_kit_path" --name "$name"
  fi
}
