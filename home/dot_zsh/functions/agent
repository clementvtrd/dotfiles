agent() {
  local name=${PWD:t}
  local mode_kit_path="$HOME/.sbx_kits/claude.zip"
  sbx kit pack --output "$mode_kit_path" "$HOME/.sbx_kits/claude"

  if sbx ls --quiet | grep -qx "$name"; then
    sbx run claude --name "$name"
  else
    sbx run claude --kit "$mode_kit_path" --name "$name"
  fi
}
